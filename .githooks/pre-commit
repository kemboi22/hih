#!/bin/sh

set -e

echo "=== Pre-commit hook: format & lint ==="

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
  echo "No staged .go files — skipping."
  exit 0
fi

echo "Running gofmt..."
for f in $STAGED_GO_FILES; do
  if [ -f "$f" ]; then
    gofmt -w "$f"
  fi
done

git diff --cached --name-only --diff-filter=ACM | grep '\.go$' | xargs git add 2>/dev/null || true

echo "Running go vet..."
go vet ./...

echo "=== All checks passed ==="
